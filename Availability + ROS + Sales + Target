def apply_corrections(df, label):
    """
    Apply PRODUCT_CORRECTIONS to the product/AG description column of a DataFrame.

    Column detection priority:
      1. "Product Hierarchy Description"  -- used by Sales_L7D
      2. Any alias in AG_ALIASES          -- used by the 6 new WTD/MTD files
         ("Assortment Group", "AG Name", "AG", "SUB_NAME")

    Returns (corrected_df, count_of_corrections_made).
    """
    # Detect which column to apply corrections to
    if "Product Hierarchy Description" in df.columns:
        target_col = "Product Hierarchy Description"
    else:
        target_col = find_ag_column(df, label)

    print(f"  [{label}]  correction column  ->  '{target_col}'")

    total = 0
    for old_val, new_val in PRODUCT_CORRECTIONS.items():
        mask  = df[target_col] == old_val
        count = mask.sum()
        if count > 0:
            df.loc[mask, target_col] = new_val
            total += count
            print(f"  [{label}]  ✓ {count:>4} rows  '{old_val}'  →  '{new_val}'")
    if total == 0:
        print(f"  [{label}]  ✓ No matching values found — no corrections needed")
    return df, total

