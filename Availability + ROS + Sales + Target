# Location column may be "Stock Location" or "stocklocationname"
# ══════════════════════════════════════════════════════════════════════════════
LOC_ALIASES = ["Stock Location", "stocklocationname", "Business Area"]

def find_loc_column(df, file_label):
    """Return the first location alias column found in df, or exit with a clear error."""
    for alias in LOC_ALIASES:
        if alias in df.columns:
            return alias
    print(f"\n  ⛔ ERROR: No Location column found in '{file_label}'")
    print(f"  Looked for : {LOC_ALIASES}")
    print(f"  Found cols : {list(df.columns)}")
