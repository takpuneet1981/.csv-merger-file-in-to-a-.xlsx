# ══════════════════════════════════════════════════════════════════════════════
# MATCH / REJECT REPORTER
# Prints how many FK rows from a source file matched TW_P and how many did not
# ══════════════════════════════════════════════════════════════════════════════
def report_match(label, source_keys, base_keys):
    matched  = len(source_keys & base_keys)
    rejected = len(source_keys - base_keys)
    total    = len(source_keys)
    print(f"  {label:<30}  Total: {total:<6}  Matched: {matched:<6}  Rejected (no FK in TW_P): {rejected}")
    return matched, rejected

