# ── 9b: Build the spine — UNION of TW_P FKs and all sales FKs ────────────────
# Start with TW_P as the authoritative base
spine = tw_df.copy()

# Find FKs that are in sales files but NOT in TW_P
sales_only_fks = sales_fk_lookup[
    ~sales_fk_lookup["Foreign Key"].isin(tw_keys)
].copy()

print(f"  FKs only in sales files      : {len(sales_only_fks)}  (new rows added to spine)")

# For these new FKs, build skeleton rows:
#   Stock Location   = Business Area (same store number)
#   Assortment Group = SUB_NAME / Product Hierarchy Description
#   All other TW_P columns = blank
if len(sales_only_fks) > 0:
    extra_rows = pd.DataFrame({
        "Foreign Key"    : sales_only_fks["Foreign Key"].values,
        "Stock Location" : sales_only_fks["_sales_store"].values,
        "Assortment Group": sales_only_fks["_sales_ag"].values,
    })
    # All missing TW_P columns → empty string (consistent with rest of data)
    for col in spine.columns:
        if col not in extra_rows.columns:
            extra_rows[col] = ""

    extra_rows = extra_rows[spine.columns]   # ensure same column order
    spine = pd.concat([spine, extra_rows], ignore_index=True)

print(f"  Spine total rows (TW_P + new): {len(spine)}")

# ── 9c: Merge all files onto the full spine ───────────────────────────────────
match_stats = {}

def full_merge(base, right_agg, right_keys, label, value_col):
    """
    Outer-friendly merge: drops internal _loc_raw/_ag_raw helper cols
    before merging, then tracks match stats.
    """
    global match_stats
    cols_to_merge = [c for c in right_agg.columns if not c.startswith("_")]
    merged   = base.merge(right_agg[cols_to_merge], on="Foreign Key", how="left")
    matched  = merged[value_col].replace("", pd.NA).notna().sum()
    rejected = len(right_keys - set(spine["Foreign Key"]))   # should be 0 for sales files
    match_stats[label] = {"rows": len(right_keys), "matched": int(matched), "rejected": rejected}
    print(f"  ✓ {label:<22}  src_rows={len(right_keys):<6}  matched={matched:<6}  rejected={rejected}")
    return merged

merged_df = spine.copy()

merged_df = full_merge(merged_df, lw_df,           lw_keys,         "LW_A",          "LW-ValidFamiliesSite")
merged_df = full_merge(merged_df, ag_df,            ag_keys,         "TW_A",          "TW-ValidFamiliesSite")
merged_df = full_merge(merged_df, ros_agg,          sales_keys,      "Sales_L7D ROS", "TW-ROS")
if has_sales_col:
    merged_df = full_merge(merged_df, l7d_agg,      sales_keys,      "Sales_L7D L7D", "L7D_Sales")
merged_df = full_merge(merged_df, wtd_tgt_ty_agg,   wtd_tgt_ty_keys, "WTD Target TY", "WTD Target TY")
merged_df = full_merge(merged_df, wtd_sal_ty_agg,   wtd_sal_ty_keys, "WTD Sales TY",  "WTD Sales TY")
merged_df = full_merge(merged_df, mtd_tgt_ty_agg,   mtd_tgt_ty_keys, "MTD Target TY", "MTD Target TY")
merged_df = full_merge(merged_df, mtd_sal_ty_agg,   mtd_sal_ty_keys, "MTD Sales TY",  "MTD Sales TY")
merged_df = full_merge(merged_df, wtd_sal_ly_agg,   wtd_sal_ly_keys, "WTD Sales LY",  "WTD Sales LY")
merged_df = full_merge(merged_df, mtd_sal_ly_agg,   mtd_sal_ly_keys, "MTD Sales LY",  "MTD Sales LY")

# Drop the helper columns if they leaked in
merged_df = merged_df[[c for c in merged_df.columns if not c.startswith("_")]]

