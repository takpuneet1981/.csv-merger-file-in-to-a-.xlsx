def prepare_new_file(df, label):
    """
    Aggregate the numeric value column by Foreign Key.
    Auto-detects the value column as the first column that is not the
    location, AG, or Foreign Key column.

    Also returns the raw loc+ag values per FK so we can fill
    Stock Location and Assortment Group for FKs not in TW_P.

    Returns a DataFrame: [Foreign Key, Stock Location, Assortment Group, <label>]
    """
    loc_col = find_loc_column(df, label)
    ag_col  = find_ag_column(df, label)

    skip_cols = set(LOC_ALIASES + AG_ALIASES + ["Foreign Key"])
    value_candidates = [c for c in df.columns if c not in skip_cols]

    if not value_candidates:
        print(f"  ⛔ ERROR: No value column found in '{label}'")
        print(f"  All columns: {list(df.columns)}")
        exit()

    value_col = value_candidates[0]
    print(f"  {label:<20}  value col detected: '{value_col}'")

    df[value_col] = pd.to_numeric(df[value_col], errors='coerce').fillna(0)

    # Aggregate value by FK
    agg = df.groupby("Foreign Key", as_index=False)[value_col].sum()
    agg = agg.rename(columns={value_col: label})

    # Also carry the raw Store and AG name for FK spine building
    # (take first occurrence per FK — store number and AG name don't vary within a FK)
    loc_ag = df.groupby("Foreign Key", as_index=False).agg(
        _loc_raw=(loc_col, "first"),
        _ag_raw=(ag_col,  "first"),
    )
    agg = agg.merge(loc_ag, on="Foreign Key", how="left")
    return agg

