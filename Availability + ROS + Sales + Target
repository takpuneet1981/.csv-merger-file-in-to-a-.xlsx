# AG COLUMN RESOLVER (Step-2 — flexible FK header)
# The Assortment Group column may be named differently across files:
#   "Assortment Group", "AG", or "SUB_NAME"
# This function finds whichever one exists in a given DataFrame
# ══════════════════════════════════════════════════════════════════════════════
AG_ALIASES = ["Assortment Group", "AG Name", "AG", "SUB_NAME"]   # ← "AG Name" added

def find_ag_column(df, file_label):
    """Return the first AG alias column found in df, or exit with a clear error."""
    for alias in AG_ALIASES:
        if alias in df.columns:
            return alias
    print(f"\n  ⛔ ERROR: No AG column found in '{file_label}'")
    print(f"  Looked for : {AG_ALIASES}")
    print(f"  Found cols : {list(df.columns)}")
    exit()

