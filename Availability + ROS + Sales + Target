# FOREIGN KEY FUNCTION
# Removes special chars, keeps spaces, converts to UPPERCASE
# ══════════════════════════════════════════════════════════════════════════════
def clean_key(value):
    cleaned = re.sub(r'[^a-zA-Z0-9 ]', '', str(value).strip())
    return cleaned.upper()

