    "Stock Location",
    "Stock Location Description",
    "Area",
    "Region",
    "District",
    "Format",
    "Store Class",
    "Stop Replenishment",
    "Assortment Group",
    "Assortment Group Description",
    "Display Group",
    "TW-Total Inventory In Pipe",
    "TW-SKU Families",
    "TW-Valid SKU Families",
    "TW-Newly Invalid Families",
    "TW-Expired Invalid Families",
    "TW-MBQ",
    "TW-Total Inventory at Site",
    "TW-Variety Target",
    "TW-ROS",
]

# Add date column pairs in ascending order — date col then _A col
date_ordered_cols = []
for date_col, min_col in date_col_pairs:
    date_ordered_cols.append(date_col)
    date_ordered_cols.append(min_col)

# Final column list — only keep columns that exist in merged_df
final_columns = base_columns + date_ordered_cols
final_columns = [col for col in final_columns if col in merged_df.columns]
merged_df     = merged_df[final_columns]

print(f"  ✓ Total columns in output   :  {len(merged_df.columns)}")
print(f"\n  Final column positions:")
print(f"  {'-'*60}")
for i, col in enumerate(merged_df.columns, 1):
    tag = ""
    if col == "TW-ROS":
        tag = "  ← from Sales_L7D"
    elif col.endswith("_A"):
        tag = f"  ← MIN(TW-Variety Target, {col[:-2]})"
    elif col.isdigit():
        tag = f"  ← ValidFamiliesSite from {col}.csv"
    print(f"  {i:>3}.  {col}{tag}")

