# FOREIGN KEY FUNCTION
# Removes special characters, keeps spaces, converts to UPPERCASE
# Ensures case-insensitive matching across all files
# ══════════════════════════════════════════════════════════════════════════════
def clean_key(value):
    cleaned = re.sub(r'[^a-zA-Z0-9 ]', '', str(value).strip())
    return cleaned.upper()

def make_foreign_key(df, loc_col, ag_col):
    """Create Foreign Key by combining location + assortment group columns"""
    return df[loc_col].apply(clean_key) + df[ag_col].apply(clean_key)

# ══════════════════════════════════════════════════════════════════════════════
# STEP 1: Load TW_P — Main file
# Base file — all other files merged into this
# TW_P uses: "Stock Location" + "Assortment Group" for Foreign Key
# ══════════════════════════════════════════════════════════════════════════════
print("\n" + "=" * 70)
print("  STEP 1: Loading TW_P (Main File)...")
print("-" * 70)

if not tw_path.exists():
    print(f"  ⛔ ERROR: TW_P.csv not found at {tw_path}")
    exit()

tw_df         = pd.read_csv(tw_path, dtype=str, keep_default_na=False, na_filter=False, encoding='utf-8-sig')
tw_df.columns = tw_df.columns.str.strip()

print(f"  ✓ TW_P loaded          :  {len(tw_df)} rows  |  {len(tw_df.columns)} columns")
print(f"    Columns              :  {list(tw_df.columns)}")

# Rename columns as per convention
tw_df = tw_df.rename(columns={
